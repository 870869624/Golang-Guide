      "order_by": "(tenant_id, logging_at, log_type, defense_type, principal_name, group_name, agent_ip, hostname)",
      "ttl": "toDateTime(logging_at) + INTERVAL 1 year to VOLUME 'cold'",
      "settings": "storage_policy = 'ttl'",
      "id": "String",
      "message_type": "Int32",
      "log_type": "String",
      "logged_at": "Int64",
      "logging_at": "Int64 DEFAULT 0",
      "agent_id": "String",
      "agent_ip": "String",
