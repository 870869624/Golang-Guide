      "dev_type": "String DEFAULT ''",
      "dev_id": "String DEFAULT ''",
      "action": "String DEFAULT ''"
    },
    "alarm_log": {
      "engine": "MergeTree",
      "partition_by": "toYYYYMM(toDateTime(logged_at))",
      "order_by": "(tenant_id, product, logged_at, alarm_event, alarm_event_zh, alarm_level, alarm_content)",
      "ttl": "toDateTime(logged_at) + INTERVAL 1 year to VOLUME 'cold'",
      "settings": "storage_policy = 'ttl'",
      "id": "String",
      "message_type": "Int32",
      "tenant_id": "String",
      "product": "String",
      "alarm_event": "String",
      "alarm_event_zh": "String",
