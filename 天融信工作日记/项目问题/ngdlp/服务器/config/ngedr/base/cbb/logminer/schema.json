      "engine": "MergeTree",
      "partition_by": "toYYYYMM(toDateTime(logged_at))",
      "order_by": "(tenant_id, logged_at, alarm_level)",
      "ttl": "toDateTime(logged_at) + INTERVAL 1 year to VOLUME 'cold'",
      "settings": "storage_policy = 'ttl'",
      "id": "String DEFAULT ''",
      "tenant_id": "String DEFAULT ''",
      "principal_name": "String DEFAULT ''",
      "client_ip": "String DEFAULT ''",
      "alarm_rule_name": "String DEFAULT ''",
      "alarm_level": "Int32 DEFAULT 0",
      "alarm_content": "String DEFAULT ''",
      "group_id": "String DEFAULT ''",
      "group_name": "String DEFAULT ''",
      "alarm_describe": "String DEFAULT ''",
      "client_id": "String DEFAULT ''",
