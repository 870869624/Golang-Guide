      "new_configuration": "String DEFAULT ''",
      "virusdb_version": "String DEFAULT ''",
      "duration": "Int64 DEFAULT 0",
      "start_at": "Int64 DEFAULT 0",
      "end_at": "Int64 DEFAULT 0",
      "virus_num": "Int64 DEFAULT 0",
      "result_value": "String DEFAULT ''",
      "virus_name": "String DEFAULT ''",
      "virus_type": "String DEFAULT ''",
      "file_path": "String DEFAULT ''",
      "virus_path": "String DEFAULT ''",
      "result": "String DEFAULT ''",
      "isolation_result": "String DEFAULT ''",
      "reason": "String DEFAULT ''",
      "md5": "String DEFAULT ''",
      "sha1": "String DEFAULT ''",
      "sha256": "String DEFAULT ''",
      "pid": "String DEFAULT ''",
      "cmdline": "String DEFAULT ''",
