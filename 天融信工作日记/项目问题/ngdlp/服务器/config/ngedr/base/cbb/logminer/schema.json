      "tenant_id": "String",
      "log_class": "Int32 DEFAULT 0",
      "log_level": "Int32 DEFAULT 0",
      "description": "String DEFAULT ''",
      "platform": "String DEFAULT ''",
      "attach_file_id": "String DEFAULT ''",
