<?xml version="1.0"?>
<clickhouse>
    <profiles>
        <default>
            <load_balancing>random</load_balancing>
            <!-- byte 10GB-->
            <max_memory_usage>10000000000</max_memory_usage>
            <!-- byte 2MB-->
            <max_query_size>2097152</max_query_size>
            <!-- byte 5GB-->
            <max_bytes_before_external_sort>5000000000</max_bytes_before_external_sort>
            <!-- byte 5GB-->
            <max_bytes_before_external_group_by>5000000000</max_bytes_before_external_group_by>
            <optimize_aggregation_in_order>1</optimize_aggregation_in_order>
            <group_by_two_level_threshold>100000</group_by_two_level_threshold>
            <!-- byte 5GB-->
            <group_by_two_level_threshold_bytes>5000000000</group_by_two_level_threshold_bytes>
        </default>
        <readonly>
            <readonly>1</readonly>
        </readonly>
    </profiles>
    <users>
        <default>
            <password from_env="CLICKHOUSE_ADMIN_PASSWORD"></password>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>default</profile>
            <quota>default</quota>
        </default>
    </users>
    <quotas>
        <default>
            <interval>
                <!-- Length of interval. -->
                <duration>3600</duration>
                <queries>0</queries>
                <errors>0</errors>
                <result_rows>0</result_rows>
                <read_rows>0</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </default>
    </quotas>
</clickhouse>
